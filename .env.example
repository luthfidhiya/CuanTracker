# Google Service Account credentials
# Get these from your Google Cloud Console > IAM & Admin > Service Accounts
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# Google Spreadsheet ID
# Found in the spreadsheet URL: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# Basic Auth — set this to protect the app from public access
# Leave empty to disable auth (useful for local dev)
APP_PASSWORD=your_strong_password_here
